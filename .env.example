# Copy to .env and fill in values - never commit .env to Git

APP_NAME="Molescan Backend"
DEBUG=false

# Model
MODEL_CHECKPOINT=google/vit-base-patch16-224
MODEL_WEIGHTS_PATH=weights/molescan_vit.pt
NUM_CLASSES=3
IMAGE_SIZE=224

# TTA (thesis Appendix A.1 hyperparameters)
TTA_ENABLED=true
TTA_LEARNING_RATE=0.0001
TTA_STEPS=1
TTA_EPISODIC=true

# Batch-size-1 deployment fix (option c: high-threshold skip)
TTA_ENTROPY_THRESHOLD=99.0

# Inference uncertainty bands
CONFIDENCE_HIGH=0.85
CONFIDENCE_MEDIUM=0.60

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1
